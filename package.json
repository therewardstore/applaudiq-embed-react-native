{
  "name": "@applaudiq/embed-react-native",
  "version": "1.0.0",
  "description": "React Native SDK to embed the Applaud IQ recognition portal (auto + manual login, native SSO). Works with bare React Native and Expo.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.tsx",
  "source": "src/index.tsx",
  "files": [
    "src",
    "lib",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "bob build",
    "build": "bob build",
    "typecheck": "tsc --noEmit",
    "release": "release-it"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react-native",
    "expo",
    "applaudiq",
    "embed",
    "sso",
    "webview",
    "recognition"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/therewardstore/applaudiq-embed-react-native.git"
  },
  "homepage": "https://github.com/therewardstore/applaudiq-embed-react-native#readme",
  "bugs": {
    "url": "https://github.com/therewardstore/applaudiq-embed-react-native/issues"
  },
  "author": "Arulraj V <abofficial1997@gmail.com>",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.71",
    "react-native-webview": ">=13"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "react": "18.2.0",
    "react-native": "0.74.0",
    "react-native-builder-bob": "^0.30.0",
    "react-native-webview": "13.8.6",
    "release-it": "^17.10.0",
    "typescript": "^5.4.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}